# Optional: API key for AI-powered profile rewriting (profile text).
# Set one of the two. Claude is used if ANTHROPIC_API_KEY is set, otherwise OpenAI.
# If unset or invalid, the profile is left unchanged and a warning is shown.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Brand Check tool ---
# All three keys are required for the brand-check feature.
# Alternatively, paste them directly in the UI (not persisted).
OPENAI_API_KEY=
GEMINI_API_KEY=
# ANTHROPIC_API_KEY already set above
